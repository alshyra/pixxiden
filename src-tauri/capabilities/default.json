{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for PixiDen",
  "windows": [
    "main",
    "game-overlay",
    "epic-auth",
    "gog-auth",
    "amazon-auth"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-set-always-on-top",
    "core:window:allow-is-visible",
    "core:webview:allow-create-webview-window",
    "core:event:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/legendary",
          "sidecar": true,
          "args": true
        },
        {
          "name": "binaries/gogdl",
          "sidecar": true,
          "args": true
        },
        {
          "name": "binaries/nile",
          "sidecar": true,
          "args": true
        },
        {
          "name": "binaries/umu-run-wrapper",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-open",
    "log:allow-log",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "log:default",
    "dialog:default",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/.config/**"
        },
        {
          "path": "$HOME/.local/**"
        },
        {
          "path": "$HOME/.var/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/.config/heroic/**"
        },
        {
          "path": "$HOME/.var/app/com.heroicgameslauncher.hgl/config/heroic/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        {
          "path": "$HOME/.config/heroic/**"
        },
        {
          "path": "$HOME/.var/app/com.heroicgameslauncher.hgl/config/heroic/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        {
          "path": "$APPDATA/runners/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-app-read",
      "allow": [
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-app-write",
      "allow": [
        {
          "path": "$APPCONFIG/*"
        },
        {
          "path": "$APPDATA/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-appconfig-write-recursive",
      "allow": [
        {
          "path": "$APPCONFIG/*",
          "recursive": true
        }
      ]
    },
    {
      "identifier": "fs:allow-app-meta",
      "allow": [
        {
          "path": "$APPCONFIG/*"
        },
        {
          "path": "$APPDATA/*"
        }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://*"
        },
        {
          "url": "http://*"
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/legendary",
          "sidecar": true,
          "args": true
        },
        {
          "name": "binaries/gogdl",
          "sidecar": true,
          "args": true
        },
        {
          "name": "binaries/nile",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}