{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pixxiden",
  "version": "0.1.0",
  "identifier": "com.Pixxiden.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pixxiden",
        "url": "index.html",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "center": true,
        "resizable": false,
        "maximized": true,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPCONFIG/**",
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/pixxiden.png"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": [
          "libc6:i386",
          "libgl1:i386",
          "libfreetype6:i386",
          "libx11-6:i386",
          "libxext6:i386",
          "libxrandr2:i386",
          "libxrender1:i386",
          "libxcursor1:i386",
          "libxi6:i386",
          "libxcomposite1:i386",
          "libxinerama1:i386",
          "libasound2t64:i386",
          "libfontconfig1:i386",
          "libpulse0:i386",
          "libdbus-1-3:i386"
        ]
      }
    },
    "externalBin": [
      "binaries/legendary",
      "binaries/nile",
      "binaries/gogdl",
      "binaries/umu-run-wrapper"
    ],
    "resources": [
      "resources/*"
    ]
  }
}